# ─── PostgreSQL ─────────────────────────────────────
POSTGRES_USER=sber_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=sber_grace
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_CONTAINER_NAME=sber_postgres

# ─── Ollama ─────────────────────────────────────────
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_CONTAINER_NAME=sber_ollama

# ─── Redis ──────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_CONTAINER_NAME=sber_redis

# ─── Backend ────────────────────────────────────────
BACKEND_PORT=8000
BACKEND_CONTAINER_NAME=sber_backend

# ─── Nginx ──────────────────────────────────────────
NGINX_PORT=80
NGINX_CONTAINER_NAME=sber_nginx

# ─── App ────────────────────────────────────────────
APP_DEBUG=false

# ─── VK Bot ─────────────────────────────────────────
VK_BOT_TOKEN=YOUR_VK_BOT_TOKEN
VK_USER_ID=0
VK_API_VERSION=5.199
